---
interface Props {
  cmd: string;
  description?: string;
  copyable?: boolean;
}

const { cmd, description, copyable = true } = Astro.props;
---

<div class="command-item" data-command={cmd}>
  {description && <div class="command-description">{description}</div>}
  <div class="command-wrapper">
    <code class="command-text">{cmd}</code>
    {
      copyable && (
        <button
          class="command-copy"
          data-command={cmd}
          aria-label="Copy command"
          title="Copy command"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
        </button>
      )
    }
  </div>
</div>

<script>
  import { attachCopyButtons } from '../../../utils/clipboard';

  function initCommandReference() {
    attachCopyButtons('.command-copy', (button) => button.getAttribute('data-command'));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCommandReference);
  } else {
    initCommandReference();
  }

  document.addEventListener('astro:page-load', initCommandReference);
</script>

<style>
  .command-item {
    margin: 1.5rem 0;
  }

  .command-description {
    color: var(--fg-muted);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .command-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    padding: 0.75rem 1rem;
    font-family: 'Inconsolata', monospace;
  }

  .command-text {
    flex: 1;
    color: var(--accent-green);
    font-size: 0.875rem;
    background: transparent;
    padding: 0;
    border: none;
  }

  .command-copy {
    background: transparent;
    border: none;
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.25rem;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .command-copy:hover {
    background: var(--bg-tertiary);
    color: var(--fg-secondary);
  }

  .command-copy.copied {
    color: var(--accent-green);
  }

  .command-copy svg {
    width: 16px;
    height: 16px;
  }
</style>
